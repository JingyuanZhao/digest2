{
  "$schema": "https://schema.zeabur.app/template.json",
  "name": "digest2-app",
  "description": "小行星轨道分类评估工具",
  "services": [
    {
      "type": "web",
      "name": "digest2-web",
      "env": {
        "PORT": "5000",
        "FLASK_ENV": "production"
      },
      "build": {
        "command": "pip install -r requirements.txt"
      },
      "run": {
        "command": "gunicorn --workers=4 --bind=0.0.0.0:$PORT app:app"
      }
    }
  ]
}